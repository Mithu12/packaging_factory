# E2E Testing specific gitignore

# Test results and artifacts
test-results/
playwright-report/
reports/
coverage/

# Screenshots and videos from failed tests
*.png
*.webm
*.zip

# Authentication state
config/auth-state.json

# Environment variables
.env

# Node modules (if different from root)
node_modules/

# Temporary files
*.tmp
temp/
tmp/

# Test data backups
*.backup
*.bak

# Logs specific to e2e testing
*.log
logs/

# OS generated files
.DS_Store
Thumbs.db
