{
  "name": "erp-system-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for ERP System using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:brands": "playwright test tests/brands",
    "test:categories": "playwright test tests/categories",
    "test:origins": "playwright test tests/origins",
    "test:api-only": "playwright test --grep=\"API Tests\"",
    "test:ui-only": "playwright test --grep=\"UI Tests\"",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen",
    "setup": "ts-node utils/setup-test-data.ts",
    "cleanup": "ts-node utils/cleanup-test-data.ts",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "automation",
    "erp"
  ],
  "author": "ERP System Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.6.0",
    "@types/pg": "^8.10.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "pg": "^8.11.3"
  }
}
