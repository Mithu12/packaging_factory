{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "outDir": "dist"
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts",
    "global-setup.ts",
    "global-teardown.ts",
    "fixtures/**/*.ts",
    "scripts/**/*.ts",
    "utils/**/*.ts"
  ]
}
