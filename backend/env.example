# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_system
DB_USER=postgres
DB_PASSWORD=your_password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# License Configuration
LICENSE_FILE_PATH=./license.lic
LICENSE_ENCRYPTION_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS