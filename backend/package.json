{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "ERP System Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:packages": "npm --prefix packages/inventory run build",
    "build": "rm -rf dist && tsc && tsc-alias && mkdir -p dist/utils && cp src/utils/quotation-pdf-background.png dist/utils/quotation-pdf-background.png && cp src/utils/quotation-logo.png dist/utils/quotation-logo.png || true",
    "build:prod": "npm run build && tsx scripts/obfuscate.ts",
    "obfuscate": "tsx scripts/obfuscate.ts",
    "generate:license": "tsx scripts/generateLicense.ts",
    "start": "node dist/index.js",
    "db:migrate": "npx tsx src/database/simple-migrator.ts migrate",
    "db:migrate:info": "npx tsx src/database/simple-migrator.ts info",
    "db:validate": "npx tsx src/database/validate-migrations.ts",
    "db:migrate:flyway": "tsx src/database/flyway-manager.ts migrate",
    "db:migrate:legacy": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.6",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "puppeteer": "^24.37.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/puppeteer": "^7.0.4",
    "javascript-obfuscator": "^4.1.1",
    "node-flywaydb": "^3.0.7",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
